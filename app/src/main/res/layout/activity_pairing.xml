<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- 角色標籤（頂部）-->
    <TextView
        android:id="@+id/tvRole"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="傳送方"
        android:textSize="14sp"
        android:textColor="@color/on_surface_variant"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:background="@drawable/chip_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp"/>

    <!-- NFC 動畫區（中央）
         正式版替換為 Lottie:
         <com.airbnb.lottie.LottieAnimationView
             app:lottie_rawRes="@raw/nfc_pulse"
             app:lottie_autoPlay="true"
             app:lottie_loop="true"/> -->
    <View
        android:id="@+id/nfcAnimView"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/nfc_circle_bg"
        app:layout_constraintTop_toBottomOf="@id/tvRole"
        app:layout_constraintBottom_toTopOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <!-- 狀態文字 -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="正在建立連線…"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/on_surface"
        app:layout_constraintTop_toBottomOf="@id/nfcAnimView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <!-- 提示文字 -->
    <TextView
        android:id="@+id/tvHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="輕碰兩台手機 NFC 感應區"
        android:textSize="14sp"
        android:textColor="@color/on_surface_variant"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- 取消按鈕（底部）-->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="取消"
        style="@style/Widget.Material3.Button.TextButton"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="48dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>

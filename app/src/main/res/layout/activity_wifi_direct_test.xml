<?xml version="1.0" encoding="utf-8"?>
<!--
    Wi-Fi Direct 單機 / 雙機手動測試畫面。
    僅供開發除錯使用，正式版可從 AndroidManifest 移除此 Activity。
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <!-- 標題 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Wi-Fi Direct 測試台"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:paddingBottom="8dp"/>

    <!-- 當前狀態列 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="狀態："
            android:textSize="14sp"
            android:textColor="#616161"/>

        <TextView
            android:id="@+id/tvState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="IDLE"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:paddingStart="4dp"/>
    </LinearLayout>

    <!-- 憑證顯示 -->
    <TextView
        android:id="@+id/tvCredential"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="（憑證尚未產生）"
        android:textSize="12sp"
        android:textColor="#37474F"
        android:fontFamily="monospace"
        android:background="#ECEFF1"
        android:padding="8dp"
        android:layout_marginBottom="12dp"/>

    <!-- 按鈕列：GO 端 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="── 傳送方 (GO) ──────────────────"
        android:textSize="12sp"
        android:textColor="#9E9E9E"
        android:paddingBottom="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnCreateGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="建立群組"
            android:backgroundTint="#1565C0"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnRemoveGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="解散群組"
            android:backgroundTint="#B71C1C"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <!-- 按鈕列：Client 端 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="── 接收方 (Client) ──────────────"
        android:textSize="12sp"
        android:textColor="#9E9E9E"
        android:paddingBottom="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="12dp">

        <!-- 手動輸入憑證欄位（模擬 NFC 傳來的資料）-->
        <EditText
            android:id="@+id/etSsid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="SSID（從 GO 畫面複製）"
            android:inputType="text"
            android:textSize="13sp"/>

        <EditText
            android:id="@+id/etPassphrase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Passphrase"
            android:inputType="textPassword"
            android:textSize="13sp"/>

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="連線至 GO"
            android:backgroundTint="#2E7D32"/>
    </LinearLayout>

    <!-- 全域重置 -->
    <Button
        android:id="@+id/btnReset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="全部重置 (Reset)"
        android:backgroundTint="#546E7A"
        android:layout_marginBottom="12dp"/>

    <!-- 即時 Log 輸出 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="── Log ──────────────────────────"
        android:textSize="12sp"
        android:textColor="#9E9E9E"
        android:paddingBottom="4dp"/>

    <ScrollView
        android:id="@+id/scrollLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#263238">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="#80CBC4"
            android:fontFamily="monospace"
            android:padding="8dp"/>
    </ScrollView>

</LinearLayout>
